  class SelectionPage
  class TaskBookApprovalPage
  class ProposalReviewPage
  class MidtermReviewPage
  class ReviewAssignmentPage
  class ScorePublishPage
}

package "Control" {
  class TopicController
  class SelectionController
  class TaskBookController
  class ProposalController
  class MidtermController
  class ReviewController
